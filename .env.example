# APP Configuration
APP_NAME=SISIKITA
NODE_ENV=development
API_PREFIX=api
CORS_ORIGIN=*
APP_PORT=3001
APP_URL=http://localhost:3001

# JsonWebToken
JWT_SECRET=your-jwt-secret
JWT_EXPIRATION=jwt-expiration

# Swagger API Docs
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Database Configuration
DATABASE_URL=your-database-url

# ImageKit Configuration
IMAGEKIT_PUBLIC_KEY=your-imagekit-public_key
IMAGEKIT_PRIVATE_KEY=your-imagekit-private_key
IMAGEKIT_URL_ENDPOINT=your-imagekit-endpoint

# ─── OAuth Configuration ─────────────────────────────────────────────────────

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Twitter / X OAuth2 
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Frontend redirect URL setelah OAuth sukses (query: ?token=<accessToken>)
OAUTH_SUCCESS_REDIRECT=http://localhost:3000/oauth/success